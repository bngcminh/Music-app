doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title 
    link(rel="stylesheet", href="/public/css/home.css")
    link(rel="stylesheet", href="/public/css/songs.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .app-container
      aside.sidebar
        .sidebar-header
          .logo
            i.fas.fa-music
            span MusicApp

        nav.nav-menu
          a.nav-item.active(href="/")
            i.fas.fa-home
            span Khám Phá
          //- a.nav-item(href="#")
          //-   i.fas.fa-chart-line
          //-   span BXH Nhạc Mới
          //- a.nav-item(href="#")
          //-   i.fas.fa-fire
          //-   span Chủ Đề & Thể Loại
          //- a.nav-item(href="#")
          //-   i.fas.fa-star
          //-   span Top 100
          //- a.nav-item(href="#")
          //-   i.fas.fa-podcast
          //-   span Podcast

        .divider

        .library-section
          h4.library-title Thư Viện
          //- a.nav-item(href="#")
          //-   i.fas.fa-heart
          //-   span Yêu Thích
          //- a.nav-item(href="#")
          //-   i.fas.fa-clock-rotate-left
          //-   span Nghe Gần Đây
          a.nav-item(href="#")
            i.fas.fa-folder
            span Playlist Của Tôi

      main.main-content
        header.main-header.song-header
          .header-left

          .search-box
            i.fas.fa-search
            input(type="text" placeholder="Tìm kiếm")

          .header-actions
            if user
              .user-menu
                .user-avatar
                  i.fas.fa-user-circle
                span.user-name= user.username
                .dropdown-menu
                  a(href="/profile")
                    i.fas.fa-user
                    span Trang cá nhân
                  if user.role === 'admin'
                    a(href="/admin")
                      i.fas.fa-cog
                      span Admin Dashboard
                  a(href="/logout")
                    i.fas.fa-sign-out-alt
                    span Đăng xuất
            else
              a.btn.btn-login(href="/login") Đăng nhập
              a.btn.btn-register(href="/register") Đăng ký

        .content-wrapper.song-detail-page
          section.song-hero
            .song-hero-art
              .art-frame
                img#songCover.song-cover-image(src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=900&q=80" alt="Cover bÃ i hÃ¡t")
              .art-glow

            .song-hero-body
              //- .hero-badge Single Spotlight
              h2#songTitle.song-title #{song.songName}

              .song-artist-row
                .artist-pill
                  .artist-pill-avatar
                    i.fas.fa-user
                  .artist-pill-copy
                    span.artist-pill-label #{song.artist.name}

                //- .song-stat-chip
                //-   i.fas.fa-clock
                //-   span#songDuration 02:08
                //- .song-stat-chip
                //-   i.fas.fa-compact-disc
                //-   span#songGenre Dark Pop

              .song-reaction-row
                //- .reaction-block
                //-   button.reaction-btn(type="button" aria-label="Yeu thich")
                //-     i.fas.fa-heart
                //-   span#songLikes 2.4K
                //- .reaction-block
                //-   button.reaction-btn(type="button" aria-label="Chia se")
                //-     i.fas.fa-share-nodes
                //-   span#songShares 318
                //- .reaction-block
                //-   button.reaction-btn(type="button" aria-label="Them vao playlist")
                //-     i.fas.fa-ellipsis

              .song-hero-actions
                button#heroPlayBtn.btn-hero.btn-hero-primary(type="button")
                  i.fas.fa-play
                  span Phát ngay
                button.btn-hero(type="button")
                  i.fas.fa-list-ul
                  span Thêm vào danh sách phát
                button.btn-hero(type="button")
                  i.fas.fa-light.fa-plus
                  span Thêm vào Playlist
                //- a.btn-hero(href="#relatedSongs")
                //-   i.fas.fa-arrow-down
                //-   span Xem gợi Ã½

              //- .song-facts
              //-   .fact-card
              //-     span.fact-label Nam phat hanh
              //-     strong#songYear 2024
              //-   .fact-card
              //-     span.fact-label Hang dia
              //-     strong#songLabel Neon Room
              //-   .fact-card
              //-     span.fact-label TÃ¢m trang
              //-     strong#songMood Moody, Night Drive

          .detail-grid
            section.lyrics-panel.panel-card
              .panel-heading
                div
                  h3 Lời bài hát
              #songLyrics.lyrics-body
                p Lời hát sẽ sớm cập nhật...

            aside.info-stack
              section.panel-card.artist-panel
                .panel-heading
                  div
                    h3 Nghệ sĩ
                    .artist-info
                      .artist-card-avatar
                        img#artistAvatar(src=`${song.artist.avatar}` alt="Anh nghe si")
                      .artist-card-copy
                        h4#artistName #{song.artist.name}
                  //-   p#artistFollowers 8 nguoi theo doi
                  //-   p#artistBio Artist theo duoi mau sac dark-pop va alternative electronic.
                  //- button.artist-follow-btn(type="button") Theo dõi

    include partials/music-player.pug
    script(src="/public/js/home.js")
    script(src="/public/js/songs.js")
