doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="/public/css/auth.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    title Đăng Ký - MusicApp
  body
    .auth-container
      //- Left Side - Branding
      .auth-left
        .auth-brand
          a.brand-logo(href="/")
            i.fas.fa-music
            span MusicApp
          h1 Bắt Đầu Hành Trình!
          p Tạo tài khoản để trải nghiệm âm nhạc không giới hạn

          .features
            .feature-item
              i.fas.fa-check-circle
              span Miễn phí tạo tài khoản
            .feature-item
              i.fas.fa-infinity
              span Nghe nhạc không giới hạn
            .feature-item
              i.fas.fa-list-ul
              span Tạo playlist riêng
            .feature-item
              i.fas.fa-star
              span Theo dõi nghệ sĩ yêu thích

        .auth-decoration
          .circle.circle-1
          .circle.circle-2
          .circle.circle-3

      //- Right Side - Register Form
      .auth-right
        .auth-close
          a(href="/")
            i.fas.fa-times

        .auth-form-container
          .auth-header
            h2 Đăng Ký
            p Tạo tài khoản mới để bắt đầu

          //- Social Register
          .social-login
            button.social-btn.google(type="button")
              i.fab.fa-google
              span Đăng ký với Google
            button.social-btn.facebook(type="button")
              i.fab.fa-facebook-f
              span Đăng ký với Facebook

          .divider
            span hoặc

          //- Register Form
          form.auth-form#register-form(action="/register", method="post")
            .form-group
              label(for="username")
                i.fas.fa-user
                span Tên hiển thị
              input.form-control#username(
                type="text"
                name="username"
                placeholder="Nhập tên hiển thị của bạn"
                required
              )

            .form-group
              label(for="email")
                i.fas.fa-envelope
                span Email
              input.form-control#email(
                type="email"
                name="email"
                placeholder="example@email.com"
                required
              )

            .form-row
              .form-group
                label(for="password")
                  i.fas.fa-lock
                  span Mật khẩu
                .password-wrapper
                  input.form-control#password(
                    type="password"
                    name="password"
                    placeholder="Tạo mật khẩu"
                    required
                  )
                  button.password-toggle(type="button")
                    i.fas.fa-eye

              .form-group
                label(for="confirm-password")
                  i.fas.fa-lock
                  span Xác nhận
                .password-wrapper
                  input.form-control#confirm-password(
                    type="password"
                    name="confirmPassword"
                    placeholder="Nhập lại mật khẩu"
                    required
                  )
                  button.password-toggle(type="button")
                    i.fas.fa-eye

            .password-strength
              .strength-bar
                .strength-fill
              .strength-text Mật khẩu: Yếu

            label.checkbox-wrapper.terms
              input(type="checkbox" name="agree" required)
              span Tôi đồng ý với
                a(href="/terms" target="_blank") Điều khoản dịch vụ
                |  và
                a(href="/privacy" target="_blank") Chính sách bảo mật

            button.btn.btn-primary(type="submit")
              span Tạo Tài Khoản
              i.fas.fa-arrow-right

          .auth-footer
            p Đã có tài khoản?
              a(href="/login") Đăng nhập ngay

    script(src="/public/js/auth.js")
