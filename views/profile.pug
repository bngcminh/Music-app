doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Trang Cá Nhân - MusicApp
    link(rel="stylesheet", href="/public/css/home.css")
    link(rel="stylesheet", href="/public/css/profile.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .app-container
      //- Sidebar
      aside.sidebar
        .sidebar-header
          .logo
            i.fas.fa-music
            span MusicApp

        nav.sidebar-nav
          a.nav-item.active(href="/")
            i.fas.fa-home
            span Khám Phá
          //- a.nav-item(href="#")
          //-   i.fas.fa-chart-line
          //-   span BXH Nhạc Mới
          //- a.nav-item(href="#")
          //-   i.fas.fa-fire
          //-   span Chủ Đề & Thể Loại
          //- a.nav-item(href="#")
          //-   i.fas.fa-star
          //-   span Top 100
          //- a.nav-item(href="#")
          //-   i.fas.fa-podcast
          //-   span Podcast

          .divider

        .library-section
          h4.library-title Thư Viện
          //- a.nav-item(href="#")
          //-   i.fas.fa-heart
          //-   span Yêu Thích
          //- a.nav-item(href="#")
          //-   i.fas.fa-clock-rotate-left
          //-   span Nghe Gần Đây
          a.nav-item(href="#")
            i.fas.fa-folder
            span Playlist Của Tôi

      //- Main Content
      main.main-content
        //- Header
        header.main-header
          .header-left

        //- Profile Content
        .content-wrapper
          .profile-container
            //- Profile Header
            .profile-header
              .profile-cover
                .cover-overlay
                  button.btn-change-cover
                    i.fas.fa-camera
                    span Đổi ảnh bìa

              .profile-info-header
                .profile-avatar-large
                  .avatar-wrapper
                    img#profileAvatarPreview(src="/public/images/default-avatar.png" alt="Avatar")
                    .avatar-overlay
                      label.avatar-upload(for="avatarUpload")
                        i.fas.fa-camera
                        input#avatarUpload(type="file" accept="image/*" hidden)

                .profile-details
                  h2.profile-name= user ? user.username : 'Guest'
                  p.profile-email= user ? user.email : ''
                  .profile-stats
                    //- .stat-item
                    //-   span.stat-number 0
                    //-   span.stat-label Playlist
                    //- .stat-item
                    //-   span.stat-number 0
                    //-   span.stat-label Bài Hát
                    //- .stat-item
                    //-   span.stat-number 0
                    //-   span.stat-label Theo Dõi

            //- Tabs Navigation
            .profile-tabs
              button.tab-btn.active(data-tab="overview") Tổng Quan
              button.tab-btn(data-tab="edit") Chỉnh Sửa
              button.tab-btn(data-tab="playlists") Playlist
              button.tab-btn(data-tab="security") Bảo Mật

            //- Tab Content
            .tab-content
              //- Overview Tab
              //- .tab-panel.active#overviewTab
              //-   .overview-grid
              //-     .overview-card
              //-       .card-header
              //-         h3 Hoạt Động Gần Đây
              //-         button.btn-icon
              //-           i.fas.fa-ellipsis-v
              //-       .activity-list
              //-         .activity-item
              //-           i.fas.fa-music
              //-           .activity-info
              //-             p.activity-text Đã thêm bài hát
              //-             p.activity-time 2 giờ trước
              //-         .activity-item
              //-           i.fas.fa-list-ul
              //-           .activity-info
              //-             p.activity-text Tạo playlist mới
              //-             p.activity-time 1 ngày trước

                  //- .overview-card
                  //-   .card-header
                  //-     h3 Thống Kê
                  //-     button.btn-icon
                  //-       i.fas.fa-chart-line
                  //-   .stats-grid
                  //-     .stat-box
                  //-       i.fas.fa-headphones
                  //-       .stat-content
                  //-         p.stat-value 127
                  //-         p.stat-label Giờ nghe
                  //-     .stat-box
                  //-       i.fas.fa-music
                  //-       .stat-content
                  //-         p.stat-value 348
                  //-         p.stat-label Bài hát
                  //-           //- Edit Profile Tab
              .tab-panel#editTab
                .edit-form-container
                  form#editProfileForm
                    .form-section
                      h3 Thông Tin Cá Nhân

                      .form-row
                        .form-group
                          label(for="editUsername") Tên Người Dùng
                          input#editUsername(type="text" value=user ? user.username : '' placeholder="Nhập tên người dùng")

                        .form-group
                          label(for="editEmail") Email
                          input#editEmail(type="email" value=user ? user.email : '' placeholder="Nhập email")

                      .form-actions
                        button.btn.btn-secondary(type="button") Hủy
                        button.btn.btn-primary(type="submit") Lưu Thay Đổi

              //- Playlists Tab
              .tab-panel#playlistsTab
                .playlists-management
                  .playlists-header-tab
                    h3 Playlist của tôi
                    a.btn.btn-primary(href="/playlists/create")
                      i.fas.fa-plus
                      span Tạo Mới

                  .playlists-list
                    .playlist-item
                      .playlist-thumbnail-small
                        i.fas.fa-list-ul
                      .playlist-info-item
                        h4 Nhạc Yêu Thích
                        p 15 bài hát • Công khai
                      .playlist-actions-item
                        button.btn-icon(title="Chỉnh sửa")
                          i.fas.fa-edit
                        button.btn-icon(title="Xóa")
                          i.fas.fa-trash

                    .playlist-item
                      .playlist-thumbnail-small
                        i.fas.fa-list-ul
                      .playlist-info-item
                        h4 Nhạc Buồn
                        p 8 bài hát • Riêng tư
                      .playlist-actions-item
                        button.btn-icon(title="Chỉnh sửa")
                          i.fas.fa-edit
                        button.btn-icon(title="Xóa")
                          i.fas.fa-trash

              //- Security Tab
              .tab-panel#securityTab
                .security-container
                  form#changePasswordForm
                    .form-section
                      h3 Đổi Mật Khẩu

                      .form-group
                        label(for="currentPassword") Mật Khẩu Hiện Tại
                        input#currentPassword(type="password" placeholder="Nhập mật khẩu hiện tại")

                      .form-group
                        label(for="newPassword") Mật Khẩu Mới
                        input#newPassword(type="password" placeholder="Nhập mật khẩu mới")

                      .form-group
                        label(for="confirmPassword") Xác Nhận Mật Khẩu
                        input#confirmPassword(type="password" placeholder="Nhập lại mật khẩu mới")

                      .form-actions
                        button.btn.btn-primary(type="submit") Đổi Mật Khẩu
    include partials/music-player.pug
    script(src="/public/js/home.js")
    script(src="/public/js/profile.js")
