doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quản Lý Người Dùng - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      //- Sidebar
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản Trị Hệ Thống

        nav.admin-nav
          a.nav-tab(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab.active(href="/admin/users")
            i.fas.fa-users
            span Người Dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ Sĩ
          a.nav-tab(href="/admin/songs")
            i.fas.fa-music
            span Bài Hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về Trang Chủ

      //- Main Content
      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quản Lý Người Dùng
            p#page-desc Quản lý tài khoản người dùng

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                p.user-name Admin User
                p.user-role Super Admin

        #notification.notification

        //- Users Panel
        section.panel.active(data-panel="users")
          .panel-header
            h2
              i.fas.fa-users
              span Quản Lý Người Dùng

          .form-card
            h3 Tạo Người Dùng Mới
            form.admin-form#user-create-form(action="/users" method="post")
              .form-row
                .form-group
                  label
                    i.fas.fa-user
                    span Tên người dùng
                  input.form-control(type="text" name="username" placeholder="Nhập tên người dùng" required)

                .form-group
                  label
                    i.fas.fa-envelope
                    span Email
                  input.form-control(type="email" name="email" placeholder="example@email.com" required)

              .form-row
                .form-group
                  label
                    i.fas.fa-lock
                    span Mật khẩu
                  input.form-control(type="password" name="password" placeholder="Nhập mật khẩu" required)

                .form-group
                  label
                    i.fas.fa-user-tag
                    span Vai trò
                  select.form-control(name="role")
                    option(value="user" selected) User
                    option(value="admin") Admin

              button.btn.btn-primary(type="submit")
                i.fas.fa-plus
                span Tạo Người Dùng

          .panel-header.mt-4
            h3 Danh Sách Người Dùng
            button.btn.btn-secondary#refresh-users(type="button")
              i.fas.fa-sync-alt
              span Tải Lại

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Avatar
                  th Tên
                  th Email
                  th Vai Trò
                  th Trạng Thái
                  th Ngày Tạo
                  th Thao Tác
              tbody#users-body
                tr
                  td(colspan="8")
                    .loading
                      i.fas.fa-spinner.fa-spin
                      span Đang tải dữ liệu...

    script(src="/public/js/admin.js")