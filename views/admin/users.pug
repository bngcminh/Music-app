doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quan Ly Nguoi Dung - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quan Tri He Thong

        nav.admin-nav
          a.nav-tab.active(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Nguoi Dung
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghe Si
          a.nav-tab(href="/admin/songs")
            i.fas.fa-user
            span Bai Hat
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Ve Trang Chu

      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quan Ly Nguoi Dung
            p#page-desc Quan ly tai khoan nguoi dung

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        section.panel.active(data-panel="users")
          .panel-header
            h2
              i.fas.fa-users
              span Quan Ly Nguoi Dung

          .panel-header.mt-4
            h3 Danh Sach Nguoi Dung

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Avatar
                  th Ten
                  th Vai Tro
                  th Thao Tac
              tbody#users-body
                each user, index in users
                  tr
                    td #{index + 1}
                    td
                      img(src=user.avatar alt="" width="80")
                    td #{user.username}
                    td #{user.role}
                    td
                      .action-buttons
                        form(action=`/admin/delete/user/${user._id}` method="GET")
                          button.btn.btn-danger.btn-sm.admin-action-btn(type="submit")
                            i.fas.fa-trash
                            span Xoa
                        a.btn.btn-secondary.btn-sm.admin-action-btn(href=`/admin/user/${user._id}`)
                          i.fas.fa-pen
                          span Sua
