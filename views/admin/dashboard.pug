doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Dashboard - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      //- Sidebar
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản Trị Hệ Thống

        nav.admin-nav
          a.nav-tab.active(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Người Dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ Sĩ
          a.nav-tab(href="/admin/songs")
            i.fas.fa-user
            span Bài Hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về Trang Chủ

      //- Main Content
      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Dashboard

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        //- Dashboard Panel
        section.panel.active(data-panel="dashboard")
          .stats-grid
            .stat-card
              .stat-icon.bg-primary
                i.fas.fa-users
              .stat-info
                h3 1,234
                p Người Dùng
            .stat-card
              .stat-icon.bg-success
                i.fas.fa-microphone
              .stat-info
                h3 456
                p Nghệ Sĩ
            .stat-card
              .stat-icon.bg-warning
                i.fas.fa-music
              .stat-info
                h3 5,678
                p Bài Hát
            .stat-card
              .stat-icon.bg-info
                i.fas.fa-list-ul
              .stat-info
                h3 89
                p Playlists
    script(src="/public/js/admin.js")