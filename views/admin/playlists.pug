doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quan Ly Playlist - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quan Tri He Thong

        nav.admin-nav
          a.nav-tab.active(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Nguoi Dung
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghe Si
          a.nav-tab(href="/admin/songs")
            i.fas.fa-user
            span Bai Hat
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Ve Trang Chu

      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quan Ly Playlist
            p#page-desc Tao va quan ly playlist

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        section.panel.active(data-panel="playlists")
          .panel-header
            h2
              i.fas.fa-list-ul
              span Quan Ly Playlist

          .form-card
            h3 Tao Playlist Moi
            form.admin-form#playlist-create-form(action="/admin/create/playlist" method="post" enctype="multipart/form-data")
              .form-row
                .form-group
                  label
                    i.fas.fa-heading
                    span Ten Playlist
                  input.form-control(type="text" name="playlistName" placeholder="Nhap ten playlist" required)

                .form-group
                  label
                    i.fas.fa-link
                    span Anh Playlist
                  input.form-control(type="file" name="coverUrl" accept="image/*")

                .form-group
                  label
                    i.fas.fa-link
                    span Them bai hat
                  select.form-control(name="songs" multiple size="6")
                    each song in songs
                      option(value=song._id) #{song.songName}

              button.btn.btn-primary(type="submit")
                i.fas.fa-plus
                span Tao Playlist

          .panel-header.mt-4
            h3 Danh Sach Playlist

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Ten Playlist
                  th Cover
                  th So Bai Hat
                  th Thao Tac
              tbody#playlists-body
                each playlist, index in playlists
                  tr
                    td #{index + 1}
                    td #{playlist.playlistName}
                    td
                      img(src=playlist.coverUrl alt="Cover" width="80")
                    td #{playlist.songs.length}
                    td
                      .action-buttons
                        form(action=`/admin/delete/playlist/${playlist._id}` method="GET")
                          button.btn.btn-danger.btn-sm.admin-action-btn(type="submit")
                            i.fas.fa-trash
                            span Xoa
                        a.btn.btn-secondary.btn-sm.admin-action-btn(href=`/admin/playlist/${playlist._id}`)
                          i.fas.fa-pen
                          span Sua
