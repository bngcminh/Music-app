doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Cập nhật playlist - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản trị hệ thống

        nav.admin-nav
          a.nav-tab(href="/admin")
            i.fas.fa-chart-line
            span Bảng điều khiển
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Người dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ sĩ
          a.nav-tab(href="/admin/songs")
            i.fas.fa-music
            span Bài hát
          a.nav-tab.active(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về trang chủ

      main.admin-main
        header.admin-header
          .header-left
            h1 Cập nhật playlist
            p Cập nhật thông tin hiển thị và tóm tắt nội dung playlist
          .header-right
            a.btn.btn-secondary(href="/admin/playlists")
              i.fas.fa-arrow-left
              span Quay lại

        section.panel.active
          .panel-header
            h2
              i.fas.fa-list-check
              span Chỉnh sửa playlist

          .update-shell
            .entity-card
              .entity-media
                  img.entity-cover-image(src=artist.coverUrl)

              .entity-content
                h3= playlistData && playlistData.playlistName ? playlistData.playlistName : 'Playlist'
                p= `${songCount} bài hát hiện có`

                .entity-meta
                  span.meta-chip
                    i.fas.fa-music
                    |  #{songCount} bài hát
                  span.meta-chip
                    i.fas.fa-pen
                    |  #{updatedAt}

                if songCount
                  .tag-list
                    each item, index in songs
                      if index < 4
                        - const songLabel = item && item.songName ? item.songName : item
                        span.meta-chip= songLabel
                      else if index === 4
                        span.meta-chip +#{songCount - 4} mục
                else
                  p.entity-description Chưa có bài hát trong playlist này.

            .form-card
              h3 Nội dung playlist
              form.admin-form(action=`/admin/update/playlist/${playlist._id}`, method="post" enctype="multipart/form-data")
                .form-row
                  .form-group
                    label(for="playlistName")
                      i.fas.fa-heading
                      span Tên playlist
                    input#playlistName.form-control(type="text", name="playlistName", value=playlist.playlistName, placeholder="Nhập tên playlist")

                  .form-group
                    label(for="coverUrl")
                      i.fas.fa-image
                      span Cover URL
                    input#coverUrl.form-control(type="file", name="coverUrl", placeholder="/upload/cover/playlist.jpg")

                .form-row
                  .form-group
                    label(for="songs")
                      i.fas.fa-list
                      span Danh sách bài hát
                    input#songs.form-control(type="text", name="songs", value=songs.map(item => item && item._id ? item._id : item).join(', '), placeholder="Nhập ID bài hát, cách nhau bởi dấu phẩy")

                .form-actions
                  a.btn.btn-outline(href="/admin/playlists") Hủy
                  button.btn.btn-primary(type="submit")
                    i.fas.fa-floppy-disk
                    span Lưu thay đổi
