doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Cập nhật bài hát - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    - const songData = typeof song !== 'undefined' ? song : null
    - const coverUrl = songData && songData.coverUrl ? songData.coverUrl : ''
    - const audioUrl = songData && songData.audioUrl ? songData.audioUrl : ''
    - const artistName = songData && songData.artist && songData.artist.name ? songData.artist.name : (songData && songData.artist ? songData.artist : '')
    - const updatedAt = songData && songData.updatedAt ? String(songData.updatedAt).slice(0, 10) : 'Chưa cập nhật'

    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản trị hệ thống

        nav.admin-nav
          a.nav-tab(href="/admin")
            i.fas.fa-chart-line
            span Bảng điều khiển
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Người dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ sĩ
          a.nav-tab.active(href="/admin/songs")
            i.fas.fa-music
            span Bài hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về trang chủ

      main.admin-main
        header.admin-header
          .header-left
            h1 Cập nhật bài hát
            p Chỉnh sửa thông tin hiển thị của bài hát
          .header-right
            a.btn.btn-secondary(href="/admin/songs")
              i.fas.fa-arrow-left
              span Quay lại

        section.panel.active
          .panel-header
            h2
              i.fas.fa-compact-disc
              span Chỉnh sửa bài hát

          .update-shell
            .entity-card
              .entity-media
                if coverUrl
                  img.entity-cover-image(src=coverUrl, alt=songData && songData.songName ? songData.songName : 'Cover bài hát')
                else
                  .entity-cover.entity-cover-icon
                    i.fas.fa-music

              .entity-content
                h3= songData && songData.songName ? songData.songName : 'Bài hát'

            .form-card
              h3 Nội dung chính
              form.admin-form(action=`/admin/update/song/${song._id}`, method="POST" enctype="multipart/form-data")
                .form-row
                  .form-group
                    label(for="songName")
                      i.fas.fa-heading
                      span Tên bài hát
                    input#songName.form-control(type="text", name="songName", value=song.songName, placeholder="Nhập tên bài hát")

                  .form-group
                    label(for="artist")
                      i.fas.fa-microphone
                      span Nghệ sĩ
                    input#artist.form-control(type="text", name="artist", value=song.artist.name, placeholder="Nhập tên nghệ sĩ")

                .form-row
                  .form-group
                    label(for="audioUrl")
                      i.fas.fa-file-audio
                      span Audio URL
                    input#audioUrl.form-control(type="file", name="audioUrl", placeholder="/upload/audio/song.mp3", accept="audio/*")

                  .form-group
                    label(for="coverUrl")
                      i.fas.fa-image
                      span Cover URL
                    input#coverUrl.form-control(type="file", name="coverUrl", placeholder="/upload/cover/song.jpg", accept="image/*")

                .form-actions
                  a.btn.btn-outline(href="/admin/songs") Hủy
                  button.btn.btn-primary(type="submit")
                    i.fas.fa-floppy-disk
                    span Lưu thay đổi
