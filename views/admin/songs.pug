doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quản Lý Bài Hát - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      //- Sidebar
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản Trị Hệ Thống

        nav.admin-nav
          a.nav-tab.active(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Người Dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ Sĩ
          a.nav-tab(href="/admin/songs")
            i.fas.fa-user
            span Bài Hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về Trang Chủ

      //- Main Content
      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quản Lý Bài Hát
            p#page-desc Tạo và quản lý bài hát

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        //- Songs Panel
        section.panel.active(data-panel="songs")
          .panel-header
            h2
              i.fas.fa-music
              span Quản Lý Bài Hát

          .form-card
            h3 Tạo Bài Hát Mới
            form.admin-form#song-create-form(action="/admin/create/song" method="POST" enctype="multipart/form-data")
              .form-row
                .form-group
                  label
                    i.fas.fa-heading
                    span Tên Bài Hát
                  input.form-control(type="text" name="songName" placeholder="Nhập tên bài hát" required)

                .form-group
                  label
                    i.fas.fa-microphone
                    span Nghệ Sĩ
                  input.form-control(type="text" name="artist" placeholder="Tên nghệ sĩ" required)

              .form-row
                .form-group
                  label
                    i.fas.fa-file-audio
                    span File Audio
                  input.form-control(type="file" name="audioUrl" accept="audio/*" required)

                .form-group
                  label
                    i.fas.fa-image
                    span Ảnh Bìa
                  input.form-control(type="file" name="coverUrl" accept="image/*")

              button.btn.btn-primary(type="submit")
                i.fas.fa-plus
                span Tạo Bài Hát

          .panel-header.mt-4
            h3 Danh Sách Bài Hát

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Cover
                  th Tên Bài Hát
                  th Nghệ Sĩ
                  //- th Lượt Nghe
                  //- th Thời Lượng
                  th Thao Tác
              tbody#songs-body
                each song, index in songs
                  tr
                    td #{index + 1}
                    td 
                      img(src=song.coverUrl alt="Cover" width="80")
                    td #{song.songName}
                    td #{song.artist ? song.artist.name : 'Khong co nghe si'}
                    td
                      form(action=`/admin/delete/song/${song._id}` method="GET")
                        button Xóa
                      a(href=`/admin/song/${song._id}`) Chỉnh sửa
                      