doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quản lý bài hát - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản trị hệ thống

        nav.admin-nav
          a.nav-tab(href="/admin")
            i.fas.fa-chart-line
            span Bảng điều khiển
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Người dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ sĩ
          a.nav-tab.active(href="/admin/songs")
            i.fas.fa-music
            span Bài hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về trang chủ

      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quản lý bài hát
            p#page-desc Tạo và quản lý bài hát

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        section.panel.active(data-panel="songs")
          .panel-header
            h2
              i.fas.fa-music
              span Quản lý bài hát

          .form-card
            h3 Tạo bài hát mới
            form.admin-form#song-create-form(action="/admin/create/song" method="POST" enctype="multipart/form-data")
              .form-row
                .form-group
                  label
                    i.fas.fa-heading
                    span Tên bài hát
                  input.form-control(type="text" name="songName" placeholder="Nhập tên bài hát" required)

                .form-group
                  label
                    i.fas.fa-microphone
                    span Nghệ sĩ
                  input.form-control(type="text" name="artist" placeholder="Tên nghệ sĩ" required)

              .form-row
                .form-group
                  label
                    i.fas.fa-file-audio
                    span File audio
                  input.form-control(type="file" name="audioUrl" accept="audio/*" required)

                .form-group
                  label
                    i.fas.fa-image
                    span Ảnh bìa
                  input.form-control(type="file" name="coverUrl" accept="image/*")

              button.btn.btn-primary(type="submit")
                i.fas.fa-plus
                span Tạo bài hát

          .panel-header.mt-4
            h3 Danh sách bài hát

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Cover
                  th Tên bài hát
                  th Nghệ sĩ
                  th Thao tác
              tbody#songs-body
                each song, index in songs
                  tr
                    td #{index + 1}
                    td
                      img(src=song.coverUrl alt="Cover" width="80")
                    td #{song.songName}
                    td #{song.artist ? song.artist.name : 'Không có nghệ sĩ'}
                    td
                      .action-buttons
                        form(action=`/admin/delete/song/${song._id}` method="GET")
                          button.btn.btn-danger.btn-sm.admin-action-btn(type="submit")
                            i.fas.fa-trash
                            span Xóa
                        a.btn.btn-secondary.btn-sm.admin-action-btn(href=`/admin/song/${song._id}`)
                          i.fas.fa-pen
                          span Chỉnh sửa
