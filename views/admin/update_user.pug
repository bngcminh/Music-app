doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Cập nhật người dùng - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    - const userData = typeof user !== 'undefined' ? user : null
    - const avatarUrl = userData && userData.avatar ? userData.avatar : ''

    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quản trị hệ thống

        nav.admin-nav
          a.nav-tab(href="/admin")
            i.fas.fa-chart-line
            span Bảng điều khiển
          a.nav-tab.active(href="/admin/users")
            i.fas.fa-users
            span Người dùng
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghệ sĩ
          a.nav-tab(href="/admin/songs")
            i.fas.fa-music
            span Bài hát
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Về trang chủ

      main.admin-main
        header.admin-header
          .header-left
            h1 Cập nhật người dùng
            p Điều chỉnh thông tin tài khoản trong giao diện admin
          .header-right
            a.btn.btn-secondary(href="/admin/users")
              i.fas.fa-arrow-left
              span Quay lại

        section.panel.active
          .panel-header
            h2
              i.fas.fa-user-pen
              span Chỉnh sửa tài khoản

          .update-shell
            .entity-card
              .entity-media
                if avatarUrl
                  img.entity-cover-image(src=avatarUrl, alt=userData && userData.username ? userData.username : 'Avatar người dùng')
                else
                  .entity-cover.entity-cover-icon
                    i.fas.fa-user

            .form-card
              h3 Thông tin cơ bản
              form.admin-form(action=`/admin/update/user/${user._id}` method="POST")
                .form-row
                  .form-group
                    label(for="username")
                      i.fas.fa-user
                      span Tên hiển thị
                    input#username.form-control(type="text", name="username", value=userData ? userData.username : '', placeholder="Nhập tên người dùng")

                  .form-group
                    label(for="email")
                      i.fas.fa-envelope
                      span Email
                    input#email.form-control(type="email", name="email", value=userData ? userData.email : '', placeholder="example@email.com")

                .form-row
                  .form-group
                    label(for="role")
                      i.fas.fa-user-shield
                      span Vai trò
                    select#role.form-control(name="role")
                      option(value="user", selected=!userData || userData.role === 'user') User
                      option(value="admin", selected=userData && userData.role === 'admin') Admin

                p.form-help
                  | Giao diện này chỉ tập trung vào HTML/CSS. Nếu muốn submit đúng luồng cập nhật, cần đồng bộ thêm route và xử lý form.

                .form-actions
                  a.btn.btn-outline(href="/admin/users") Hủy
                  button.btn.btn-primary(type="submit")
                    i.fas.fa-floppy-disk
                    span Lưu thay đổi
