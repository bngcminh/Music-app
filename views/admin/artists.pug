doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Quan Ly Nghe Si - Admin MusicApp
    link(rel="stylesheet", href="/public/css/admin.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .admin-wrapper
      aside.admin-sidebar
        .admin-brand
          .brand-icon
            i.fas.fa-music
          .brand-text
            h1 MusicApp Admin
            p Quan Tri He Thong

        nav.admin-nav
          a.nav-tab.active(href="/admin")
            i.fas.fa-chart-line
            span Dashboard
          a.nav-tab(href="/admin/users")
            i.fas.fa-users
            span Nguoi Dung
          a.nav-tab(href="/admin/artists")
            i.fas.fa-microphone
            span Nghe Si
          a.nav-tab(href="/admin/songs")
            i.fas.fa-user
            span Bai Hat
          a.nav-tab(href="/admin/playlists")
            i.fas.fa-list-ul
            span Playlist

        .sidebar-footer
          a.btn-back(href="/")
            i.fas.fa-arrow-left
            span Ve Trang Chu

      main.admin-main
        header.admin-header
          .header-left
            h1#page-title Quan Ly Nghe Si
            p#page-desc Tao va quan ly nghe si

          .header-right
            .user-info
              .avatar
                i.fas.fa-user-circle
              .user-detail
                if user
                  p.user-name #{user.username}

        #notification.notification

        section.panel.active(data-panel="artists")
          .panel-header
            h2
              i.fas.fa-microphone
              span Quan Ly Nghe Si

          .form-card
            h3 Tao Nghe Si Moi
            form.admin-form#artist-create-form(action="/admin/create/artist" method="post" enctype="multipart/form-data")
              .form-row
                .form-group
                  label
                    i.fas.fa-user
                    span Ten Nghe Si
                  input.form-control(type="text" name="name" placeholder="Nhap ten nghe si" required)

                .form-group
                  label
                    i.fas.fa-image
                    span Anh Dai Dien
                  input.form-control(type="file" name="avatar" accept="image/*")

              .form-group
                label
                  i.fas.fa-align-left
                  span Tieu Su
                textarea.form-control(name="bio" rows="3" placeholder="Mo ta ve nghe si...")

              button.btn.btn-primary(type="submit")
                i.fas.fa-plus
                span Tao Nghe Si

          .panel-header.mt-4
            h3 Danh Sach Nghe Si

          .data-table-container
            table.data-table
              thead
                tr
                  th #
                  th Avatar
                  th Ten Nghe Si
                  th Tieu Su
                  th Thao Tac
              tbody#artists-body
                each artist, index in artists
                  tr
                    td #{index + 1}
                    td
                      img(src=artist.avatar alt="Cover" width="80")
                    td #{artist.name}
                    td #{artist.bio}
                    td
                      .action-buttons
                        form(action=`/admin/delete/artist/${artist._id}` method="GET")
                          button.btn.btn-danger.btn-sm.admin-action-btn(type="submit")
                            i.fas.fa-trash
                            span Xoa
                        a.btn.btn-secondary.btn-sm.admin-action-btn(href=`/admin/artist/${artist._id}`)
                          i.fas.fa-pen
                          span Sua

    script(src="/public/js/admin.js")
