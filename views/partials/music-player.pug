.player-bar
  .player-content

    // ===== LEFT =====
    .player-song-info
      .player-thumbnail
        img#player-cover(src="" alt="")
      .player-details
        h4.player-song-name#player-title Tên bài hát
        p.player-artist-name#player-artist Tên nghệ sĩ

    // ===== CENTER =====
    .player-center
      .player-controls
        button.btn-control#shuffle-btn(type="button" title="Phát ngẫu nhiên")
          i.fas.fa-shuffle

        button.btn-control#prev-btn(type="button" title="Bài trước")
          i.fas.fa-backward-step

        button.btn-control.btn-play-main#play-btn(type="button" title="Phát / Tạm dừng")
          i.fas.fa-play

        button.btn-control#next-btn(type="button" title="Bài tiếp")
          i.fas.fa-forward-step

        button.btn-control#repeat-btn(type="button" title="Lặp lại: tắt / tất cả / một bài")
          i.fas.fa-repeat

      .player-timeline
        .progress-bar#progress-bar
          .progress-track
            .progress-fill#progress-fill(style="width: 0%")

    // ===== RIGHT =====
    .player-right
      button.btn-control#open-queue(type="button" title="Danh sách phát")
        i.fas.fa-list-ul

      .volume-control
        button.btn-control#volume-mute-btn(type="button" title="Tắt tiếng")
          i.fas.fa-volume-high
        .volume-slider#volume-slider(aria-label="Âm lượng")
          .volume-track#volume-track
            .volume-fill#volume-fill(style="width: 70%")

// ===== QUEUE =====
.playlist-queue-modal#playlistQueueModal
  .queue-overlay
  .queue-panel

    .queue-header
      h3 Danh sách phát
      button.btn-close-queue#closeQueueBtn
        i.fas.fa-times

    .queue-content
      .now-playing-section
        h4 Đang phát
        .now-playing-item
          .song-thumbnail-queue
            img#queue-cover(src="" alt="")
          .song-info-queue
            p.song-name#queue-title Chọn một bài hát
            p.song-artist#queue-artist ---
          .song-duration#queue-duration 0:00

      .queue-list-section
        .queue-list-header
          h4 Tiếp theo
          span.queue-count#queue-count 0 bài hát

        .queue-list#queueList
          p.empty-queue Danh sách phát trống

// ===== AUDIO (BẮT BUỘC) =====
audio#audioPlayer