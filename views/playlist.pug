doctype html
html(lang="vi")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title #{playlist.playlistName} - MusicApp
    link(rel="stylesheet", href="/public/css/home.css")
    link(rel="stylesheet", href="/public/css/playlists.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
  body
    .app-container
      aside.sidebar
        .sidebar-header
          .logo
            i.fas.fa-music
            span MusicApp

        nav.sidebar-nav
          a.nav-item.active(href="/")
            i.fas.fa-home
            span Kham Pha

        .divider

        .library-section
          h4.library-title Thu Vien
          a.nav-item(href="/profile")
            i.fas.fa-folder
            span Playlist cua toi

      main.main-content
        header.main-header.playlist-header
          .search-box
            i.fas.fa-search
            input(type="text" placeholder="Tim kiem")

          .header-actions
            if user
              .user-menu
                .user-avatar
                  i.fas.fa-user-circle
                span.user-name= user.username
                .dropdown-menu
                  a(href="/profile")
                    i.fas.fa-user
                    span Trang ca nhan
                  if user.role === 'admin'
                    a(href="/admin")
                      i.fas.fa-cog
                      span Admin Dashboard
                  a(href="/logout")
                    i.fas.fa-sign-out-alt
                    span Dang xuat
            else
              a.btn.btn-login(href="/login") Dang nhap
              a.btn.btn-register(href="/register") Dang ky

        .content-wrapper.playlist-detail-page
          section.playlist-hero
            .playlist-cover-wrap
              .playlist-cover-stack
                img#playlistCover.playlist-cover-image(src=playlist.coverUrl alt=playlist.playlistName)
              .cover-shadow

            .playlist-hero-body
              .playlist-meta-line
                span#playlistType Playlist
                span.dot-divider •
                span#playlistCountText #{songs.length} bai hat
              h2#playlistTitle.playlist-title #{playlist.playlistName}
              .playlist-main-actions
                button#playAllBtn.btn-hero.btn-hero-primary(type="button")
                  i.fas.fa-play
                  span Phat tat ca

          .playlist-layout
            section.panel-card.track-panel
              .track-table-wrap
                table.track-table
                  thead
                    tr
                      th #
                      th Tieu de
                      th Playlist
                      th Nghe si
                      th Thao tac
                  tbody#playlistTracks
                      each song, index in songs
                        tr.track-row
                          td.track-index #{index + 1}
                          td
                            a.track-main(href=`/song/${song._id}`)
                              .track-cover
                                  img(src=song.coverUrl alt=song.songName)
                              .track-copy
                                p.track-title #{song.songName}
                                p.track-subtitle #{songName}
                          td #{playlist.playlistName}
                          td #{song.artist.name}
                          td
                            a.track-action-btn(href=`/song/${song._id}/select-playlist`)
                              i.fas.fa-plus
                              span Them vao playlist

    include partials/music-player.pug
    script(src="/public/js/home.js")
